{
  "$schema": "https://railway.com/railway.schema.json",
  "build": {
    "builder": "RAILPACK"
  },
  "deploy": {
    "runtime": "V2",
    "numReplicas": 1,
    "buildCommand": "pip install -r requirements.txt && PLAYWRIGHT_BROWSERS_PATH=/app/.playwright python -m playwright install chromium",
    "startCommand": "PLAYWRIGHT_BROWSERS_PATH=/app/.playwright uvicorn app.main:app --host 0.0.0.0 --port $PORT",
    "sleepApplication": false,
    "useLegacyStacker": false,
    "ipv6EgressEnabled": false,
    "multiRegionConfig": {
      "us-west2": {
        "numReplicas": 1
      }
    },
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 10
  }
}